# ── Infrastructure credentials ─────────────────────────────────────────────
# These match the defaults hard-coded in docker-compose.yaml.
# Change them in production; for local dev the defaults work as-is.
POSTGRES_USER=fw
POSTGRES_PASSWORD=fw_secret
RABBITMQ_USER=fw
RABBITMQ_PASSWORD=fw_secret

# ── JWT ────────────────────────────────────────────────────────────────────
# RSA key files are generated by scripts/setup.sh → secrets/
# The identity-service reads these from Docker secrets (/run/secrets/…).
# No need to set a JWT secret here — keys are file-based.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Notification rules ─────────────────────────────────────────────────────
# Transactions above this amount (in VND) trigger a SPENDING_SPIKE alert.
SPENDING_SPIKE_THRESHOLD_VND=500000

# ── LLM (Phase 2 only) ─────────────────────────────────────────────────────
# Leave empty for Phase 1. insight-service stubs out LLM calls when key is absent.
GEMINI_API_KEY=your_key_here   # from aistudio.google.com