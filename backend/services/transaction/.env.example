# --- Database ---
DATABASE_URL=postgresql+asyncpg://fw:fw_secret@localhost:5432/transaction_db

# --- Messaging ---
RABBITMQ_URL=amqp://fw:fw_secret@localhost:5672/

# --- JWT (RS256, verify only) ---
# Path to the public PEM key generated by scripts/gen_keys.sh
PUBLIC_KEY_PATH=./keys/public.pem
JWT_ALGORITHM=RS256

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=transaction-service

# --- App ---
DEBUG=false
