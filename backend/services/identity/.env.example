# --- Database ---
DATABASE_URL=postgresql+asyncpg://fw:fw_secret@localhost:5432/identity_db

# --- JWT (RS256) ---
# Paths to the PEM key files generated by scripts/gen_keys.sh
PRIVATE_KEY_PATH=./keys/private.pem
PUBLIC_KEY_PATH=./keys/public.pem
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=identity-service

# --- App ---
DEBUG=false
